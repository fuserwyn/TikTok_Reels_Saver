# Токен от @BotFather (как в основном боте можно назвать TELEGRAM_API_KEY)
TELEGRAM_API_KEY=

# Альтернативное имя переменной
# BOT_TOKEN=

# PostgreSQL (Railway подставляет при подключении плагина БД к проекту)
# DATABASE_URL=postgresql://...
# Локально без SSL: DATABASE_SSL=false
# CERTIFICATE_VERIFY_FAILED при старте: DATABASE_SSL=no-verify
# STATS_ADMIN_IDS=123456789,987654321   # кто может /stats в личке (Telegram user id)

# Лимит размера файла в байтах (по умолчанию 50 МБ — лимит Telegram для видео от бота)
# MAX_UPLOAD_BYTES=52428800

# Видео после скачивания: ffmpeg +movflags faststart для iPhone (можно отключить)
# VIDEO_SKIP_FASTSTART=1
# Если на iPhone всё равно не играет — полный перекод в H.264+AAC (долго грузит CPU):
# VIDEO_TRANSCODE_IOS=1

# Netscape cookies.txt — если TikTok/Reels пишет об ошибке извлечения, задай путь
# YT_DLP_COOKIEFILE=/data/cookies.txt

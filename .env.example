# Токен от @BotFather (как в основном боте можно назвать TELEGRAM_API_KEY)
TELEGRAM_API_KEY=

# Альтернативное имя переменной
# BOT_TOKEN=

# Лимит размера файла в байтах (по умолчанию 50 МБ — лимит Telegram для видео от бота)
# MAX_UPLOAD_BYTES=52428800

# Netscape cookies.txt: TikTok/Instagram; для YouTube — если даже с обходом через android/ios клиент (по умолчанию) пишет «Sign in…»
# YT_DLP_COOKIEFILE=/data/cookies.txt
# YOUTUBE_COOKIEFILE=…  (то же, что YT_DLP, если удобнее другое имя)
# YOUTUBE_DISABLE_EXTRACTOR_BYPASS=1  (отключить моб. клиенты, только ручная отладка)

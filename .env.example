# Токен от @BotFather (как в основном боте можно назвать TELEGRAM_API_KEY)
TELEGRAM_API_KEY=

# Альтернативное имя переменной
# BOT_TOKEN=

# Куда складывать временные файлы (в Docker по умолчанию /tmp/social_fetch)
DOWNLOAD_DIR=/tmp/social_fetch

# Лимит размера файла в байтах (по умолчанию 50 МБ — лимит Telegram для видео от бота)
# MAX_UPLOAD_BYTES=52428800

# Netscape cookies.txt — если TikTok пишет «Unable to extract webpage video data»
# YT_DLP_COOKIEFILE=/data/cookies.txt

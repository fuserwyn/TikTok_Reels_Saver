# Токен от @BotFather (как в основном боте можно назвать TELEGRAM_API_KEY)
TELEGRAM_API_KEY=

# Альтернативное имя переменной
# BOT_TOKEN=

# PostgreSQL (Railway подставляет при подключении плагина БД к проекту)
# DATABASE_URL=postgresql://...
# Локально без SSL: DATABASE_SSL=false
# CERTIFICATE_VERIFY_FAILED при старте: DATABASE_SSL=no-verify
# STATS_ADMIN_IDS=123456789,987654321   # кто может /stats в личке (Telegram user id)

# Лимит скачивания (байты). Не задавай переменную — при рабочей Telethon-сессии лимит ~2 ГБ; иначе ~50 МБ.
# Явно MAX_UPLOAD_BYTES=52428800 оставляет потолок 50 МБ даже с сессией.

# Отправка видео >50 МБ: приложение my.telegram.org → api_id / api_hash; строка сессии Telethon
# (python: StringSession.save(); не публикуй в открытом виде). Аккаунт сессии должен иметь право
# писать пользователю в личку (если бот не открывает чат — попроси написать ему first).
# API_ID=
# API_HASH=
# TELEGRAM_SESSION=

# Видео для iPhone: по умолчанию перекод H.264+AAC (иначе часто «картинка стоит, звук идёт»).
# Для экономии CPU на Railway: VIDEO_LIGHTWEIGHT=1 — только faststart, без перекода.
# VIDEO_SKIP_FASTSTART=1 — даже в lightweight не делать faststart
# Старый флаг VIDEO_TRANSCODE_IOS=0 — то же что VIDEO_LIGHTWEIGHT (без перекода)

# Netscape cookies.txt — TikTok/Reels/Instagram с IP хостинга часто без этого не качаются
# YT_DLP_COOKIEFILE=/data/cookies.txt
# INSTAGRAM_APP_ID=936619743392459   # опционально, другой X-IG-App-ID (wiki yt-dlp → instagram)
# Фоновое автообновление yt-dlp раз в N часов (0/пусто = выключено)
# YT_DLP_AUTOUPDATE_HOURS=24
